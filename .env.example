# LLM 配置（使用 init_chat_model 通用初始化，不绑定厂商）
# 支持的模型提供商：openai, anthropic, together, fireworks, ollama, deepseek 等
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=

# Embedding 配置（BGE-M3，免费本地运行）
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_USE_FP16=false
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CACHE_DIR=./cache/embeddings

# Qdrant 配置
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=rag_documents
QDRANT_USE_MEMORY=false

# 文档处理配置
CHUNK_SIZE=1024
CHUNK_OVERLAP=200
SEMANTIC_CHUNKING_ENABLED=true
MAX_WORKERS=4

# OCR 配置（RapidOCR，免费，支持中英文）
OCR_ENABLED=true
OCR_DPI=300

# PDF 处理模式
PDF_USE_UNSTRUCTURED=false
PDF_EXTRACT_IMAGES=true

# 检索配置
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
BM25_WEIGHT=0.3
DENSE_WEIGHT=0.7

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=*

# 日志配置
LOG_LEVEL=INFO

# LangFuse 可观测性（可选）
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=